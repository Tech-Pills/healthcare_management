<p style="color: green"><%= notice %></p>

<% content_for :title, "Appointments" %>

<h2>Clinic Dashboard</h2>
<div style="display: flex; gap: 20px; margin-bottom: 20px;">
  <div style="padding: 15px; background: #f0f9ff; border-radius: 8px; flex: 1; text-align: center;">
    <div style="font-size: 24px; font-weight: bold;"><%= @clinic_stats[:total_patients] %></div>
    <div style="color: #666;">Patients</div>
  </div>
  <div style="padding: 15px; background: #f0fdf4; border-radius: 8px; flex: 1; text-align: center;">
    <div style="font-size: 24px; font-weight: bold;"><%= @clinic_stats[:total_appointments] %></div>
    <div style="color: #666;">Appointments</div>
  </div>
  <div style="padding: 15px; background: #fefce8; border-radius: 8px; flex: 1; text-align: center;">
    <div style="font-size: 24px; font-weight: bold;"><%= @clinic_stats[:total_staff] %></div>
    <div style="color: #666;">Staff</div>
  </div>
  <div style="padding: 15px; background: #fdf2f8; border-radius: 8px; flex: 1; text-align: center;">
    <div style="font-size: 24px; font-weight: bold;"><%= @clinic_stats[:upcoming_appointments] %></div>
    <div style="color: #666;">Upcoming</div>
  </div>
</div>

<h1>Appointments</h1>

<div id="appointments">
  <% @appointments.each do |appointment| %>
    <%= render appointment %>
    <p>
      <%= link_to "Show this appointment", appointment %>
    </p>
  <% end %>
</div>

<%= link_to "New appointment", new_appointment_path %>
